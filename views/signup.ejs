<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Signup | SyntecxHub</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background: #0f172a;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            color: #fff;
        }

        .container {
            display: flex;
            background: #111827;
            border-radius: 20px;
            overflow: hidden;
            width: 800px;
            max-width: 90%;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
        }

        .left,
        .right {
            padding: 40px;
            flex: 1;
        }

        .left {
            background: linear-gradient(135deg, #38bdf8, #0ea5e9);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            animation: fadeInLeft 1s;
            overflow: hidden;
        }

        .left img {
            width: 180px;
            height: 180px;
            border-radius: 50%;          /* circular */
            background: transparent;      /* remove white background */
            object-fit: cover;           /* cover the circle */
            object-position: 25% center; /* shift robot slightly right */
            margin-bottom: 20px;
            animation: bounce 2s infinite;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
        }

        .left h1 {
            font-size: 2rem;
            margin-bottom: 10px;
            color: #fff;
        }

        .left p {
            color: #e5e7eb;
            font-size: 1rem;
        }

        .right {
            animation: fadeInRight 1s;
        }

        .right h2 {
            color: #38bdf8;
            margin-bottom: 30px;
            text-align: center;
        }

        .right form {
            display: flex;
            flex-direction: column;
        }

        .right input {
            padding: 12px 15px;
            margin-bottom: 20px;
            border-radius: 10px;
            border: none;
            outline: none;
            font-size: 1rem;
        }

        .right button {
            padding: 12px;
            border: none;
            border-radius: 10px;
            background: #38bdf8;
            color: #0f172a;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
        }

        .right button:hover {
            background: #0ea5e9;
            transform: scale(1.05);
        }

        @keyframes fadeInLeft {
            from {
                opacity: 0;
                transform: translateX(-50px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @keyframes fadeInRight {
            from {
                opacity: 0;
                transform: translateX(50px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @keyframes bounce {
            0%, 100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-15px);
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="left">
            <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRkaeOy-VzgiIqdZIdDc6E4hKKFGqXZNid4yA&s" alt="Guide Character">
            <h1>Welcome, Future Star!</h1>
            <p>Sign up now and start building real-world skills with SyntecxHub.</p>
        </div>
        <div class="right">
            <h2>Sign Up</h2>
            <form action="/authorize/signup" method="POST">
                <input type="text" name="username" placeholder="Username" required>
                <input type="email" name="email" placeholder="Email" required>
                <input type="password" name="password" placeholder="Password" required>
                <button type="submit">Sign Up</button>
            </form>
        </div>
    </div>
</body>

</html>
